#include <stdio.h>
#include <math.h>

int main() {
    int num, originalNum, remainder, n = 0;
    double result = 0.0;

    printf("Enter an integer: ");
    scanf("%d", &num);

    originalNum = num;

    // 1. Find the number of digits in the integer
    for (originalNum = num; originalNum != 0; ++n) {
        originalNum /= 10;
    }

    originalNum = num;

    // 2. Sum the nth power of each digit
    while (originalNum != 0) {
        remainder = originalNum % 10;
        // Use round() to avoid potential precision errors with pow()
        result += pow(remainder, n);
        originalNum /= 10;
    }

    // 3. Check if the sum equals the original number
    if ((int)result == num)
        printf("%d is an Armstrong number.\n", num);
    else
        printf("%d is not an Armstrong number.\n", num);

    return 0;
}
